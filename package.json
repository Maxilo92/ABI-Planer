{
  "name": "abi-planer",
  "version": "1.24.1.8",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "sync:version": "node scripts/sync-version.mjs",
    "prebuild": "npm run sync:version",
    "build": "next build",
    "build:clean": "rm -rf .next && npm run build",
    "start": "node .next/standalone/server.js",
    "lint": "eslint .",
    "test:regressions": "node scripts/regression-guard.mjs",
    "cleanup:session-metrics": "node scripts/cleanup_session_metrics.js",
    "cleanup:session-metrics:apply": "node scripts/cleanup_session_metrics.js --apply --reset-online",
    "migrate:cards": "npx ts-node scripts/migrate_card_settings.ts",
    "migrate:visible-umlauts": "npx ts-node scripts/migrate_visible_teacher_umlauts.ts",
    "migrate:visible-umlauts:apply": "npx ts-node scripts/migrate_visible_teacher_umlauts.ts --apply",
    "boneyard:build": "boneyard-js build http://localhost:3000 http://dashboard.abi-planer-27.localhost:3000 --no-scan",
    "check": "npm run test:regressions && npx tsc --noEmit && npm run build"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.59.1",
    "@types/file-saver": "^2.0.7",
    "@types/react": "19.2.14",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.0",
    "eslint-config-next": "^16.1.7",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@tailwindcss/postcss": "^4.2.1",
    "boneyard-js": "^1.6.7",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "docx": "^9.6.1",
    "file-saver": "^2.0.5",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.7.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "next": "^16.1.7",
    "next-themes": "^0.4.6",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-easy-crop": "^5.5.6",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.0.8",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0"
  }
}
