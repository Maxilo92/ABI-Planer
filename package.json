    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@tailwindcss/postcss": "^4.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "firebase": "^12.10.0",
    "firebase-admin": "^13.7.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "next": "^16.1.7",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
