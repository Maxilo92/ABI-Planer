{
  "firestore": [
    {
      "database": "abi-data",
      "rules": "firestore.rules",
      "indexes": "firestore.indexes.json"
    }
  ],
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
