rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isLernsax() {
      return isAuthenticated() && request.auth.token.email.matches('.*@hgr-web\\.lernsax\\.de$');
    }
    
    function getProfile() {
      return get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data;
    }
    
    function isApproved() {
      return isAuthenticated() && getProfile().is_approved == true;
    }

    function isPlanner() {
      return isAuthenticated() && (
        getProfile().role == 'planner' ||
        getProfile().role == 'admin' ||
        getProfile().role == 'admin_main' ||
        getProfile().role == 'admin_co'
      );
    }

    function isAdmin() {
      return isAuthenticated() && (
        getProfile().role == 'admin' ||
        getProfile().role == 'admin_main' ||
        getProfile().role == 'admin_co'
      );
    }

    function isGroupLeader(groupName) {
      return isAuthenticated() && getProfile().planning_group == groupName && getProfile().is_group_leader == true;
    }

    function isMainAdmin() {
      return isAuthenticated() && (
        getProfile().role == 'admin_main' ||
        getProfile().role == 'admin'
      );
    }

    function isCoAdmin() {
      return isAuthenticated() && getProfile().role == 'admin_co';
    }

    match /profiles/{userId} {
      allow read: if isAuthenticated();
      allow create: if isLernsax() && request.auth.uid == userId;
      
      allow update: if (
        // Case 1: Self-update for non-admin users (cannot change role, approval, course, or group)
        (request.auth.uid == userId && !isAdmin() &&
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'is_approved', 'planning_group', 'class_name', 'timeout_until', 'timeout_reason', 'is_group_leader'])) ||

        // Case 1b: Self-update for rated_teachers
        (request.auth.uid == userId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rated_teachers'])) ||

        // Case 2: Self-update for admin users (can switch own course/group but not own timeout flags)
        (request.auth.uid == userId && isAdmin() &&
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'is_approved', 'timeout_until', 'timeout_reason', 'is_group_leader'])) ||
        
        // Case 3: Main Admin (can do anything EXCEPT demoting themselves from their role)
        (isMainAdmin() && (
          (request.auth.uid == userId && request.resource.data.role == resource.data.role) || 
          (request.auth.uid != userId)
        )) ||
        
        // Case 4: Co-Admin assignment-only update (can set course/group for all accounts, including admins)
        (isCoAdmin() && request.auth.uid != userId &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['class_name', 'planning_group'])) ||

        // Case 5: Co-Admin general update (can approve but NOT change roles and NOT touch Main Admins)
        (isCoAdmin() && resource.data.role != 'admin_main' && resource.data.role != 'admin' && request.auth.uid != userId &&
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'email'])) ||

        // Case 6: Group Leader member management (can add unassigned to own group OR remove from own group)
        (isGroupLeader(getProfile().planning_group) && request.auth.uid != userId && (
          (resource.data.planning_group == null && request.resource.data.planning_group == getProfile().planning_group) ||
          (resource.data.planning_group == getProfile().planning_group && request.resource.data.planning_group == null)
        ) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'is_approved', 'is_group_leader', 'email']))
      );
      
      allow delete: if isMainAdmin() && resource.data.role != 'admin_main' && resource.data.role != 'admin';

      match /unseen_gifts/{giftId} {
        allow read: if isAuthenticated() && request.auth.uid == userId;
        allow create: if false;
        allow update: if false;
        allow delete: if isAuthenticated() && request.auth.uid == userId;
      }
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isPlanner();
    }

    match /todos/{id} { allow read: if true; allow write: if isPlanner(); }
    match /events/{id} { 
      allow read: if true; // Guests can read calendar event details (including created_by_name)
      allow write: if isPlanner(); 
    }
    match /finances/{id} { allow read: if true; allow write: if isPlanner(); }
    match /news/{id} { 
      allow read: if true; 
      allow write: if isPlanner(); 
      
      allow update: if isPlanner() || (isApproved() && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ratings', 'comment_count', 'view_count', 'viewed_by']) &&
        (
          (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['ratings'])) ||
          (resource.data.ratings == null && request.resource.data.ratings.keys().hasOnly([request.auth.uid])) ||
          (resource.data.ratings != null && request.resource.data.ratings.diff(resource.data.ratings).affectedKeys().hasOnly([request.auth.uid]))
        )
      ));

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isApproved();
        allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.created_by == request.auth.uid);
      }
    }

    match /user_teachers/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    match /teachers/{teacherId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /teacher_ratings/{ratingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isAdmin();
    }

    match /polls/{pollId} {
      allow read: if true;
      allow write: if isPlanner();

      match /options/{optionId} {
        allow read: if true;
        allow write: if isPlanner();
      }

      match /votes/{voteId} {
        allow read: if true;
        allow create: if isAuthenticated() && request.auth.uid == voteId && request.resource.data.user_id == request.auth.uid;
        allow update: if isAuthenticated() && request.auth.uid == voteId && request.resource.data.user_id == request.auth.uid &&
          get(/databases/$(database)/documents/polls/$(pollId)).data.allow_vote_change == true;
        allow delete: if isPlanner() || (isAuthenticated() && resource.data.user_id == request.auth.uid);
      }

    }


    match /votes/{voteId} {
      allow read: if true;
      allow create: if isLernsax() && request.resource.data.user_id == request.auth.uid;
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.user_id == request.auth.uid);
    }

    match /poll_votes/{voteId} {
      allow read: if true;
      allow create, update: if isAuthenticated() && request.auth.uid == request.resource.data.user_id;
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.user_id == request.auth.uid);
    }

    match /logs/{logId} {
      allow read: if isAdmin();
        // Übergang: Bis der serverseitige Logging-Endpunkt aktiv ist, dürfen
        // freigeschaltete Nutzer nur eigene Logeinträge mit Aktions-Typ schreiben.
        allow create: if isApproved()
          && request.resource.data.user_id == request.auth.uid
          && request.resource.data.action is string;
      allow update, delete: if false;
    }
    
    match /feedback/{feedbackId} {
        allow read: if isAdmin() || (isAuthenticated() && resource.data.created_by == request.auth.uid) || (isApproved() && resource.data.is_private == false);
        allow create: if isApproved();
        allow update, delete: if isAdmin();
    }

    match /user_secrets/{userId} {
      allow read, write: if false; // Only accessible via Admin SDK
    }

    match /group_messages/{id} {
        allow read: if isApproved();
        allow create: if isApproved() && (
          (request.resource.data.type == 'internal' && request.resource.data.group_name == getProfile().planning_group) || 
          (request.resource.data.type == 'hub')
        );
        allow update, delete: if isAdmin() || isGroupLeader(resource.data.group_name) || (isAuthenticated() && resource.data.created_by == request.auth.uid);
    }

    match /delayed_actions/{id} {
      allow read: if isMainAdmin() || resource.data.status == 'pending';
      allow create: if false; // Only via Cloud Function
      allow update: if isMainAdmin() && request.resource.data.status == 'cancelled' && resource.data.status == 'pending';
      allow delete: if isMainAdmin();
    }
  }
}
