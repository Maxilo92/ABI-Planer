rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isServiceAccount() {
      return request.auth == null;
    }
    
    function isLernsax() {
      return isAuthenticated() && request.auth.token.email.matches('.*@hgr-web\\.lernsax\\.de$');
    }
    
    function getProfile() {
      return get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data;
    }
    
    function isApproved() {
      return isAuthenticated() && getProfile().is_approved == true;
    }

    function isPlanner() {
      return isAuthenticated() && (
        getProfile().role == 'planner' ||
        getProfile().role == 'admin' ||
        getProfile().role == 'admin_main' ||
        getProfile().role == 'admin_co'
      );
    }

    function isAdmin() {
      return isAuthenticated() && (
        getProfile().role == 'admin' ||
        getProfile().role == 'admin_main' ||
        getProfile().role == 'admin_co'
      );
    }

    function isGroupLeader(groupName) {
      return isAuthenticated() && groupName in getProfile().get('led_groups', []);
    }

    function isMainAdmin() {
      return isAuthenticated() && (
        getProfile().role == 'admin_main' ||
        getProfile().role == 'admin'
      );
    }

    function isCoAdmin() {
      return isAuthenticated() && getProfile().role == 'admin_co';
    }

    match /profiles/{userId} {
      allow read: if isAuthenticated() || isServiceAccount();
      allow create: if isLernsax() && request.auth.uid == userId;
      
      allow update: if (
        // Cloud Functions can update specific fields like booster_stats
        (isServiceAccount() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['booster_stats'])) ||

        // Case 1: Self-update for non-admin users (cannot change role, approval, course, group, or referral flags)
        (request.auth.uid == userId && !isAdmin() &&
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'is_approved', 'planning_groups', 'led_groups', 'class_name', 'timeout_until', 'timeout_reason', 'is_group_leader', 'referral_code', 'referred_by'])) ||

        // Case 1b: Self-update for rated_teachers
        (request.auth.uid == userId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rated_teachers'])) ||

        // Case 2: Self-update for admin users (can switch own course/group but not own timeout/referral flags)
        (request.auth.uid == userId && isAdmin() &&
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'is_approved', 'led_groups', 'timeout_until', 'timeout_reason', 'is_group_leader', 'referral_code', 'referred_by'])) ||
        
        // Case 3: Main Admin (can do anything EXCEPT demoting themselves from their role)
        (isMainAdmin() && (
          (request.auth.uid == userId && request.resource.data.role == resource.data.role) || 
          (request.auth.uid != userId)
        )) ||
        
        // Case 4: Co-Admin assignment-only update (can set course/group for all accounts, including admins)
        (isCoAdmin() && request.auth.uid != userId &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['class_name', 'planning_groups'])) ||

        // Case 5: Co-Admin general update (can approve but NOT change roles and NOT touch Main Admins)
        (isCoAdmin() && resource.data.role != 'admin_main' && resource.data.role != 'admin' && request.auth.uid != userId &&
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'email'])) ||

        // Case 6: Group Leader member management (can add/remove groups they lead)
        (getProfile().get('led_groups', []).size() > 0 && request.auth.uid != userId &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['planning_groups']) &&
         request.resource.data.planning_groups.toSet().difference(resource.data.get('planning_groups', []).toSet()).hasOnly(getProfile().get('led_groups', [])) &&
         resource.data.get('planning_groups', []).toSet().difference(request.resource.data.planning_groups.toSet()).hasOnly(getProfile().get('led_groups', [])))
      );
      
      allow delete: if isMainAdmin() && resource.data.role != 'admin_main' && resource.data.role != 'admin';

      match /unseen_gifts/{giftId} {
        allow read: if isAuthenticated() && request.auth.uid == userId;
        allow create: if false;
        allow update: if false;
        allow delete: if isAuthenticated() && request.auth.uid == userId;
      }
    }

    match /friend_requests/{requestId} {
      allow read: if isAuthenticated() && (
        resource.data.fromUserId == request.auth.uid ||
        resource.data.toUserId == request.auth.uid
      );

      allow create: if isAuthenticated()
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.fromUserId is string
        && request.resource.data.toUserId is string
        && request.resource.data.fromUserId != request.resource.data.toUserId
        && request.resource.data.status == 'pending';

      allow update: if isAuthenticated() && (
        (
          request.auth.uid == resource.data.toUserId &&
          resource.data.status == 'pending' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'responded_at', 'responded_by', 'updated_at', 'friendship_id']) &&
          request.resource.data.responded_by == request.auth.uid &&
          request.resource.data.status in ['accepted', 'declined']
        ) ||
        (
          request.auth.uid == resource.data.fromUserId &&
          resource.data.status == 'pending' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updated_at']) &&
          request.resource.data.status == 'cancelled'
        )
      );

      allow delete: if isAuthenticated() &&
        request.auth.uid == resource.data.fromUserId &&
        resource.data.status == 'pending';
    }

    match /friendships/{friendshipId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.members;

      allow create: if isAuthenticated()
        && request.resource.data.members is list
        && request.resource.data.members.size() == 2
        && request.resource.data.members[0] != request.resource.data.members[1]
        && request.resource.data.members[0] < request.resource.data.members[1]
        && request.auth.uid in request.resource.data.members
        && request.resource.data.created_by == request.auth.uid
        && request.resource.data.request_id is string
        && get(/databases/$(database)/documents/friend_requests/$(request.resource.data.request_id)).data.status == 'pending'
        && get(/databases/$(database)/documents/friend_requests/$(request.resource.data.request_id)).data.toUserId == request.auth.uid
        && get(/databases/$(database)/documents/friend_requests/$(request.resource.data.request_id)).data.fromUserId in request.resource.data.members;

      allow update: if false;

      allow delete: if isAuthenticated() && request.auth.uid in resource.data.members;
    }

    match /notifications/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId || isServiceAccount();
      allow create: if isServiceAccount();

      match /messages/{notificationId} {
        allow read: if isAuthenticated() && request.auth.uid == userId;
        allow create: if isServiceAccount();
        allow update: if isAuthenticated() && request.auth.uid == userId;
        allow delete: if isAuthenticated() && request.auth.uid == userId || isServiceAccount();
      }
    }

    match /settings/config {
      allow read: if true;
      allow write: if isPlanner();
    }

    match /settings/global {
      allow read: if true;
      allow write: if isPlanner();
    }

    match /settings/sammelkarten {
      allow read: if true; // Public read, Cloud Functions can read
      allow write: if isPlanner();
    }

    match /settings/{docId} {
      allow read: if isApproved();
      allow write: if isPlanner();
    }

    match /todos/{id} { 
      allow read: if isAuthenticated() && isLernsax(); 
      allow write: if isPlanner(); 
    }
    match /events/{id} { 
      allow read: if isAuthenticated() && isLernsax(); 
      allow write: if isPlanner(); 
    }
    match /finances/{id} { allow read: if isAuthenticated() && isLernsax(); allow write: if isPlanner(); }
    match /shop_earnings/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }
    match /news/{id} { 
      allow read: if true; 
      allow write: if isPlanner(); 
      
      allow update: if isPlanner() || (isApproved() && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions', 'comment_count', 'view_count', 'viewed_by']) &&
        (
          (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['reactions'])) ||
          (resource.data.reactions == null && request.resource.data.reactions.keys().hasOnly([request.auth.uid])) ||
          (resource.data.reactions != null && request.resource.data.reactions.diff(resource.data.reactions).affectedKeys().hasOnly([request.auth.uid]))
        )
      ));

      match /comments/{commentId} {
        allow read: if isAuthenticated() && isLernsax();
        allow create: if isApproved();
        allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.created_by == request.auth.uid);
      }
    }

    match /user_teachers/{userId} {
      allow read: if isAuthenticated() || isServiceAccount();
      allow write: if isServiceAccount() || isAdmin(); // Cloud Functions or Admin
    }

    match /teachers/{teacherId} {
      allow read: if isAuthenticated() && isLernsax();
      allow write: if isAdmin();
    }

    match /teacher_ratings/{ratingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isAdmin();
    }

    match /polls/{pollId} {
      allow read: if isAuthenticated() && isLernsax();
      allow write: if isPlanner();

      match /options/{optionId} {
        allow read: if isAuthenticated() && isLernsax();
        allow write: if isPlanner();
      }

      match /votes/{voteId} {
        allow read: if isAuthenticated() && isLernsax();
        allow create: if isAuthenticated() && request.auth.uid == voteId && request.resource.data.user_id == request.auth.uid;
        allow update: if isAuthenticated() && request.auth.uid == voteId && request.resource.data.user_id == request.auth.uid &&
          get(/databases/$(database)/documents/polls/$(pollId)).data.allow_vote_change == true;
        allow delete: if isPlanner() || (isAuthenticated() && resource.data.user_id == request.auth.uid);
      }
    }

    match /referrals/{referralId} {
      allow read: if isAuthenticated() && (
        resource.data.referrerId == request.auth.uid ||
        resource.data.referredId == request.auth.uid
      );
      allow create, update, delete: if false; // Only via Cloud Functions
    }

    match /votes/{voteId} {
      allow read: if isAuthenticated() && isLernsax();
      allow create: if isLernsax() && request.resource.data.user_id == request.auth.uid;
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.user_id == request.auth.uid);
    }

    match /poll_votes/{voteId} {
      allow read: if isAuthenticated() && isLernsax();
      allow create, update: if isAuthenticated() && request.auth.uid == request.resource.data.user_id;
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.user_id == request.auth.uid);
    }

    match /logs/{logId} {
      allow read: if isAdmin();
      allow create: if isServiceAccount() || (isApproved()
        && request.resource.data.user_id == request.auth.uid
        && request.resource.data.action is string);
      allow update, delete: if false;
    }

    match /card_proposals/{proposalId} {
      // Admin/Planer koennen alle Vorschlaege einsehen; Nutzer nur ihre eigenen.
      allow read: if isPlanner() || (isAuthenticated() && resource.data.created_by == request.auth.uid);

      // Kreativ-Labor: Nur verifizierte Mitglieder duerfen eigene Vorschlaege als pending erstellen.
      allow create: if isApproved()
        && request.resource.data.created_by == request.auth.uid
        && request.resource.data.status == 'pending';

      // Moderation (accepted/rejected/admin_note/reward_claimed) nur durch Planer/Admin.
      allow update, delete: if isPlanner();
    }
    
    match /feedback/{feedbackId} {
      allow read: if isPlanner() || (isAuthenticated() && resource.data.created_by == request.auth.uid) || (isApproved() && resource.data.is_private == false);
        allow create: if isApproved();
        allow update, delete: if isAdmin();
    }

    match /user_secrets/{userId} {
      allow read, write: if false; // Only accessible via Admin SDK
    }

    match /group_messages/{id} {
        allow read: if isApproved();
        allow create: if isApproved() && (
          (request.resource.data.type == 'internal' && request.resource.data.group_name in getProfile().get('planning_groups', [])) || 
          (request.resource.data.type == 'hub')
        );
        allow update, delete: if isAdmin() || isGroupLeader(resource.data.group_name) || (isAuthenticated() && resource.data.created_by == request.auth.uid);
    }

    match /delayed_actions/{id} {
      allow read: if isMainAdmin() || resource.data.status == 'pending';
      allow create: if false; // Only via Cloud Function
      allow update: if isMainAdmin() && request.resource.data.status == 'cancelled' && resource.data.status == 'pending';
      allow delete: if isMainAdmin();
    }
  }
}
