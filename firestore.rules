rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isLernsax() {
      return isAuthenticated() && request.auth.token.email.matches('.*@hgr-web\\.lernsax\\.de$');
    }
    
    function getProfile() {
      return get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data;
    }
    
    function isPlanner() {
      return isAuthenticated() && (
        getProfile().role == 'planner' || 
        getProfile().role == 'admin_co' || 
        getProfile().role == 'admin_main'
      );
    }
    
    function isCoAdmin() {
      return isAuthenticated() && getProfile().role == 'admin_co';
    }

    function isMainAdmin() {
      return isAuthenticated() && getProfile().role == 'admin_main';
    }

    function isAdmin() {
      return isCoAdmin() || isMainAdmin();
    }

    match /profiles/{userId} {
      allow read: if isAuthenticated();
      allow create: if isLernsax() && request.auth.uid == userId;
      
      allow update: if (
        // Case 1: Self-update (cannot change role or approval)
        (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'is_approved', 'planning_group'])) ||
        
        // Case 2: Main Admin (can do anything EXCEPT demoting themselves from admin_main)
        (isMainAdmin() && (
          (request.auth.uid == userId && request.resource.data.role == 'admin_main') || 
          (request.auth.uid != userId)
        )) ||
        
        // Case 3: Co-Admin (can approve but NOT change roles and NOT touch Main Admins)
        (isCoAdmin() && resource.data.role != 'admin_main' && request.auth.uid != userId &&
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'email']))
      );
      
      allow delete: if isMainAdmin() && resource.data.role != 'admin_main';
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isPlanner();
    }

    match /todos/{id} { allow read: if true; allow write: if isPlanner(); }
    match /events/{id} { allow read: if true; allow write: if isPlanner(); }
    match /finances/{id} { allow read: if true; allow write: if isPlanner(); }
    match /news/{id} { allow read: if true; allow write: if isPlanner(); }
    match /polls/{id} { allow read: if true; allow write: if isPlanner(); }

    match /votes/{voteId} {
      allow read: if true;
      allow create: if isLernsax() && request.resource.data.user_id == request.auth.uid;
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.user_id == request.auth.uid);
    }
  }
}
